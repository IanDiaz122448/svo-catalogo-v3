<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVO - Sistemas de Videovigilancia Orizaba</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/style.css">
    
    <style>
        :root {
            --accent-color: #38bdf8; /* Azul SVO */
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --wa-color: #25d366;
            --fb-color: #1877F2;
            --mail-color: #ea4335;
        }

        /* --- ESTILOS OPTIMIZADOS: PANEL DE PROMOS ADAPTATIVO --- */
        .promo-section {
            padding: 0; /* Ajustado para mejor integración en el Hero */
            background: transparent; 
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .swiper {
            width: 100%;
            max-width: 1000px; /* Ancho máximo del panel */
            height: auto;      /* Altura flexible para evitar saltos */
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid rgba(56, 189, 248, 0.2);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4);
            background: transparent; 
        }

        .swiper-slide img {
            width: 100%;
            height: auto;      /* Mantiene la proporción de la imagen */
            display: block;
            object-fit: contain; 
        }

        /* --- ESTILOS DE LA SECCIÓN HERO --- */
        .hero-section {
            background: radial-gradient(circle, #1e293b, #0f172a); 
            min-height: 85vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            flex-direction: column; 
            text-align: center;
            padding: 40px 15px; /* Añadido padding lateral de seguridad para móvil */
        }

        /* Sub-contenedor para panel y texto */
        .hero-content-container {
            width: 100%;
            max-width: 1200px; 
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center; /* Asegura el centrado horizontal de los hijos */
            gap: 30px; /* Espacio entre panel y texto */
        }

        /* --- SECCIÓN SERVICIOS --- */
        #servicios {
            background: var(--bg-dark);
            padding: 80px 5%; /* Un poco más compacto en móvil */
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-top: 50px;
            max-width: 1200px;
            margin: 50px auto 0;
        }

        .service-item {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .service-item:hover {
            transform: translateY(-10px);
            border-color: var(--accent-color);
            box-shadow: 0 10px 30px rgba(56, 189, 248, 0.1);
        }

        .service-icon-circle {
            width: 50px;
            height: 50px;
            background: rgba(56, 189, 248, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .service-icon-circle i {
            color: var(--accent-color);
            font-size: 1.5rem;
        }

        /* --- SECCIÓN NOSOTROS --- */
        #nosotros {
            background: #111827;
            padding: 80px 5%;
        }

        .presentation-text {
            max-width: 900px;
            margin: 0 auto 40px;
            font-size: 1.15rem;
            color: #94a3b8;
            line-height: 1.8;
            text-align: center;
        }

        .mission-vision-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            max-width: 1100px;
            margin: 0 auto 40px;
        }

        .mv-card {
            background: rgba(255, 255, 255, 0.03);
            padding: 35px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            transition: 0.3s;
        }

        .mv-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent-color);
        }

        .mv-icon {
            font-size: 2.5rem;
            color: var(--accent-color);
            margin-bottom: 20px;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 1000px;
            margin: 40px auto 0;
        }

        .value-item {
            background: rgba(56, 189, 248, 0.05);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
        }

        .value-item:hover {
            background: var(--accent-color);
            color: #000;
        }

        .value-item i { color: var(--accent-color); }
        .value-item:hover i { color: #000; }

        /* --- MENÚ DE CONTACTO DESPLEGABLE --- */
        .contact-menu {
            position: fixed;
            bottom: 25px;
            right: 25px;
            display: flex;
            flex-direction: column-reverse;
            align-items: center;
            gap: 15px;
            z-index: 1000;
        }

        .main-contact {
            width: 65px;
            height: 65px;
            background-color: var(--wa-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            box-shadow: 0 6px 15px rgba(0,0,0,0.4);
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 1001;
        }

        .extra-contact {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            font-size: 1.4rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-fb { background-color: var(--fb-color); transition-delay: 0.05s; }
        .btn-mail { background-color: var(--mail-color); transition-delay: 0.1s; }

        .contact-menu:hover .extra-contact {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .contact-menu:hover .main-contact {
            transform: scale(1.1) rotate(15deg);
        }

        .extra-
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVO - Sistemas de Videovigilancia Orizaba</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/style.css">
    
    <style>
        :root {
            --accent-color: #38bdf8; /* Azul SVO */
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --wa-color: #25d366;
            --fb-color: #1877F2;
            --mail-color: #ea4335;
        }

        /* --- ESTILOS OPTIMIZADOS: PANEL DE PROMOS ADAPTATIVO --- */
        .promo-section {
            padding: 0; 
            background: transparent; 
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .swiper {
            width: 100%;
            max-width: 1000px; 
            height: auto;      
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid rgba(56, 189, 248, 0.2);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4);
            background: transparent; 
        }

        .swiper-slide img {
            width: 100%;
            height: auto;      
            display: block;
            object-fit: contain; 
        }

        /* --- ESTILOS DE LA SECCIÓN HERO --- */
        .hero-section {
            background: radial-gradient(circle, #1e293b, #0f172a); 
            min-height: 85vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            flex-direction: column; 
            text-align: center;
            padding: 40px 0; 
        }

        /* Sub-contenedor para panel y texto */
        .hero-content-container {
            width: 100%;
            max-width: 1200px; 
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center; 
            gap: 30px; 
        }

        /* Estilo personalizado para el texto destacado del H1 */
        .hero-section h1 span {
            color: var(--accent-color);
        }

        /* --- SECCIÓN SERVICIOS --- */
        #servicios {
            background: var(--bg-dark);
            padding: 100px 5%;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-top: 50px;
            max-width: 1200px;
            margin: 50px auto 0;
        }

        .service-item {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .service-item:hover {
            transform: translateY(-10px);
            border-color: var(--accent-color);
            box-shadow: 0 10px 30px rgba(56, 189, 248, 0.1);
        }

        .service-icon-circle {
            width: 50px;
            height: 50px;
            background: rgba(56, 189, 248, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .service-icon-circle i {
            color: var(--accent-color);
            font-size: 1.5rem;
        }

        /* --- SECCIÓN NOSOTROS --- */
        #nosotros {
            background: #111827;
            padding: 100px 5%;
        }

        .presentation-text {
            max-width: 900px;
            margin: 0 auto 60px;
            font-size: 1.15rem;
            color: #94a3b8;
            line-height: 1.8;
            text-align: center;
        }

        .mission-vision-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            max-width: 1100px;
            margin: 0 auto 60px;
        }

        .mv-card {
            background: rgba(255, 255, 255, 0.03);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            transition: 0.3s;
        }

        .mv-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent-color);
        }

        .mv-icon {
            font-size: 2.5rem;
            color: var(--accent-color);
            margin-bottom: 20px;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 1000px;
            margin: 40px auto 0;
        }

        .value-item {
            background: rgba(56, 189, 248, 0.05);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid rgba(56, 189, 248, 0.1);
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
        }

        .value-item:hover {
            background: var(--accent-color);
            color: #000;
        }

        .value-item i { color: var(--accent-color); }
        .value-item:hover i { color: #000; }

        /* --- MENÚ DE CONTACTO DESPLEGABLE --- */
        .contact-menu {
            position: fixed;
            bottom: 25px;
            right: 25px;
            display: flex;
            flex-direction: column-reverse;
            align-items: center;
            gap: 15px;
            z-index: 1000;
        }

        .main-contact {
            width: 65px;
            height: 65px;
            background-color: var(--wa-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            box-shadow: 0 6px 15px rgba(0,0,0,0.4);
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 1001;
        }

        .extra-contact {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            font-size: 1.4rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-fb { background-color: var(--fb-color); transition-delay: 0.05s; }
        .btn-mail { background-color: var(--mail-color); transition-delay: 0.1s; }

        .contact-menu:hover .extra-contact {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .contact-menu:hover .main-contact {
            transform: scale(1.1) rotate(15deg);
        }

        .extra-contact:hover {
            transform: scale(1.2) !important;
        }

        .extra-contact::before {
            content: attr(data-label);
            position: absolute;
            right: 70px;
            background: rgba(0,0,0,0.85);
            color: white;
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            opacity: 0;
            transition: 0.3s;
            pointer-events: none;
            white-space: nowrap;
        }

        .extra-contact:hover::before {
            opacity: 1;
        }

        /* --- BOTÓN HAMBURGUESA PARA RESPONSIVIDAD INTEGRADA --- */
        .menu-toggle {
            display: none;
            background: none;
            border: none;
            color: #ffffff; /* Cambiado a blanco para contrastar con el fondo oscuro */
            font-size: 1.6rem;
            cursor: pointer;
            z-index: 1100;
        }

        @media (max-width: 768px) {
            .mission-vision-container, .values-grid { grid-template-columns: 1fr; }
        }

        /* Reglas adaptativas complementarias que previenen pantallas en blanco */
        @media (max-width: 992px) {
            header {
                padding: 10px 5% !important;
                display: flex !important;
                flex-direction: row !important;
                justify-content: space-between !important;
                align-items: center !important;
            }
            .menu-toggle {
                display: block !important;
            }
            nav {
                position: fixed;
                top: 75px; 
                left: -100%;
                width: 100%;
                height: calc(100vh - 75px);
                background: #0f172a; /* Cambiado al color oscuro del tema */
                transition: 0.4s ease;
                box-shadow: 0 4px 10px rgba(0,0,0,0.5);
                z-index: 999;
            }
            nav.active {
                left: 0 !important;
            }
            nav ul {
                flex-direction: column !important;
                align-items: center !important;
                padding-top: 40px !important;
                gap: 25px !important;
                display: flex !important;
            }
        }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo-container">
            <img src="/img/logo.png" alt="SVO Logo" class="logo-img">
            <span class="logo-text">Sistemas de Videovigilancia Orizaba</span>
        </a>
        
        <button class="menu-toggle" id="menuToggle">
            <i class="fas fa-bars"></i>
        </button>

        <nav id="navbar">
            <ul>
                <li><a href="/" style="color:var(--accent-color);">Inicio</a></li>
                <li><a href="#servicios">Servicios</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="#nosotros">Nosotros</a></li>
                <li><a href="/cotizar">Cotizar</a></li>
            </ul>
        </nav>
    </header>

    <!-- --- SECCIÓN HERO CORREGIDA Y CERRADA --- -->
    <section class="hero-section">
        <div class="hero-content-container">
            <% if (banners && banners.length > 0) { %>
            <div class="promo-section">
                <div class="swiper">
                    <div class="swiper-wrapper">
                        <% banners.forEach(promo => { %>
                        <div class="swiper-slide">
                            <% if (promo.enlace_whatsapp) { %>
                                <a href="<%= promo.enlace_whatsapp %>" target="_blank">
                                    <img src="<%= promo.imagen_url %>" alt="<%= promo.titulo %>">
                                </a>
                            <% } else { %>
                                <img src="<%= promo.imagen_url %>" alt="<%= promo.titulo %>">
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
            <% } %>

            <div style="text-align: center;">
                <h1>Seguridad que <span>puedes ver</span></h1>
                <p style="font-size: 1.2rem; color: #94a3b8; margin-bottom: 20px;">
                    Protegemos lo que más te importa con tecnología de videovigilancia avanzada en Orizaba y la región.
                </p>
                <a href="#servicios" style="display: inline-block; padding: 12px 30px; background: var(--accent-color); color: #0f172a; border-radius: 30px; text-decoration: none; font-weight: bold; transition: 0.3s;">
                    Ver Servicios
                </a>
            </div>
        </div>
    </section>

    <!-- --- SECCIÓN SERVICIOS ESTRUCTURADA --- -->
    <section id="servicios">
        <h2 style="text-align: center; color: #fff; font-size: 2.5rem;">Nuestros Servicios</h2>
        <div class="services-grid">
            <div class="service-item">
                <div class="service-icon-circle"><i class="fas fa-camera"></i></div>
                <h3 style="color: #fff;">Instalación de CCTV</h3>
                <p style="color: #94a3b8;">Sistemas de cámaras de alta definición y tecnología IP para monitoreo continuo.</p>
            </div>
            <div class="service-item">
                <div class="service-icon-circle"><i class="fas fa-tools"></i></div>
                <h3 style="color: #fff;">Mantenimiento Técnico</h3>
                <p style="color: #94a3b8;">Soporte preventivo y correctivo para asegurar la estabilidad de tus redes de seguridad.</p>
            </div>
            <div class="service-item">
                <div class="service-icon-circle"><i class="fas fa-shield-alt"></i></div>
                <h3 style="color: #fff;">Configuración de Redes</h3>
                <p style="color: #94a3b8;">Optimización de topologías locales y visualización remota a través de plataformas móviles y de escritorio.</p>
            </div>
        </div>
    </section>

    <!-- --- SECCIÓN NOSOTROS ESTRUCTURADA --- -->
    <section id="nosotros">
        <h2 style="text-align: center; color: #fff; font-size: 2.5rem; margin-bottom: 30px;">Sobre Nosotros</h2>
        <p class="presentation-text">
            En Sistemas de Videovigilancia Orizaba nos dedicamos a ofrecer soluciones integrales de seguridad electrónica, adaptándonos a las necesidades de hogares, comercios e industrias de la zona.
        </p>
        
        <div class="mission-vision-container">
            <div class="mv-card">
                <div class="mv-icon"><i class="fas fa-bullseye"></i></div>
                <h3 style="color: #fff; margin-bottom: 15px;">Misión</h3>
                <p style="color: #94a3b8;">Proveer tranquilidad y protección a nuestros clientes mediante la implementación de infraestructura tecnológica de vanguardia y un servicio técnico de excelencia.</p>
            </div>
            <div class="mv-card">
                <div class="mv-icon"><i class="fas fa-eye"></i></div>
                <h3 style="color: #fff; margin-bottom: 15px;">Visión</h3>
                <p style="color: #94a3b8;">Ser el referente líder en sistemas de seguridad y monitoreo digital en la región de Orizaba, distinguidos por la calidad de nuestro soporte y la confiabilidad de nuestros sistemas.</p>
            </div>
        </div>

        <div class="values-grid">
            <div class="value-item"><i class="fas fa-check-circle"></i> <span style="color: #fff;">Calidad</span></div>
            <div class="value-item"><i class="fas fa-handshake"></i> <span style="color: #fff;">Compromiso</span></div>
            <div class="value-item"><i class="fas fa-shield-alt"></i> <span style="color: #fff;">Confianza</span></div>
        </div>
    </section>

    <!-- --- MENÚ DE CONTACTO FLOTANTE --- -->
    <div class="contact-menu">
        <div class="main-contact">
            <i class="fab fa-whatsapp"></i>
        </div>
        <a href="https://facebook.com" target="_blank" class="extra-contact btn-fb" data-label="Facebook">
            <i class="fab fa-facebook-f"></i>
        </a>
        <a href="mailto:contacto@svo.com" class="extra-contact btn-mail" data-label="Correo">
            <i class="far fa-envelope"></i>
        </a>
    </div>

    <!-- --- SCRIPTS DE FUNCIONALIDAD --- -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        // Inicialización de Swiper para el panel adaptativo de promos
        const swiper = new Swiper('.swiper', {
            loop: true,
            autoplay: {
                delay: 4000,
                disableOnInteraction: false,
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
        });

        // Lógica del Botón Hamburguesa para la barra de navegación móvil
        const menuToggle = document.getElementById('menuToggle');
        const navbar = document.getElementById('navbar');

        menuToggle.addEventListener('click', () => {
            navbar.classList.toggle('active');
            
            // Cambiar dinámicamente el icono (barras / equis)
            const icon = menuToggle.querySelector('i');
            if (navbar.classList.contains('active')) {
                icon.className = 'fas fa-times';
            } else {
                icon.className = 'fas fa-bars';
            }
        });

        // Cerrar el menú al dar clic en algún enlace
        document.querySelectorAll('#navbar a').forEach(link => {
            link.addEventListener('click', () => {
                navbar.classList.remove('active');
                menuToggle.querySelector('i').className = 'fas fa-bars';
            });
        });
    </script>
</body>
</html>
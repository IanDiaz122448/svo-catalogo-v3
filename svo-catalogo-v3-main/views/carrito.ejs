<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVO - Tu Carrito de Compras</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --accent-color: #00aeef;
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --card-border: rgba(56, 189, 248, 0.15);
            --wa-color: #25d366;
        }
        body { background-color: var(--bg-dark); color: white; font-family: 'Segoe UI', sans-serif; margin: 0; padding-top: 120px; }
        
        header { background: #ffffff; position: fixed; width: 100%; top: 0; left: 0; z-index: 1000; display: flex; justify-content: space-between; align-items: center; padding: 12px 8%; box-sizing: border-box; border-bottom: 2px solid #f3f4f6; }
        .logo-link { display: flex; align-items: center; text-decoration: none; gap: 15px; }
        .logo-img { height: 55px; }
        .logo-text { color: #003366; font-family: 'Arial Black', sans-serif; font-size: 0.95rem; line-height: 1.1; font-weight: 900; }
        nav ul { list-style: none; display: flex; gap: 30px; }
        nav ul li a { text-decoration: none; color: #1f2937; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; }

        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        .cart-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; }
        .cart-card { background: var(--card-bg); border: 1px solid var(--card-border); padding: 25px; border-radius: 16px; }
        
        .cart-item { display: flex; align-items: center; gap: 20px; padding: 15px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .cart-item img { width: 70px; height: 70px; object-fit: contain; background: white; border-radius: 8px; padding: 5px; }
        .item-details { flex: 1; }
        .item-details h4 { margin: 0 0 5px 0; font-size: 1.1rem; }
        .item-details p { margin: 0; color: #94a3b8; font-size: 0.85rem; }
        
        .qty-controls { display: flex; align-items: center; gap: 10px; }
        .qty-btn { background: var(--accent-color); border: none; color: white; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-weight: bold; }
        .delete-btn { background: none; border: none; color: #ea4335; cursor: pointer; font-size: 1.1rem; margin-left: 15px; }

        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-size: 0.85rem; color: #cbd5e1; }
        .form-group input { width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: #0f172a; color: white; box-sizing: border-box; }

        .btn-checkout { width: 100%; background: linear-gradient(135deg, var(--wa-color), #16a34a); color: white; border: none; padding: 15px; border-radius: 10px; font-weight: bold; text-transform: uppercase; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 1rem; margin-top: 15px; }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo-link">
            <img src="/img/logo.png" alt="SVO Logo" class="logo-img">
            <div class="logo-text">SISTEMAS DE<br>VIDEOVIGILANCIA<br>ORIZABA</div>
        </a>
        <nav id="navbar">
            <ul>
                <li><a href="/">Inicio</a></li>
                <li><a href="#servicios">Servicios</a></li>
                <li><a href="/proyectos">Proyectos</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="#nosotros">Nosotros</a></li>
                <li><a href="/cotizar">Cotizar</a></li>
                <li>
                    <a href="/carrito" class="cart-nav-link">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-badge" id="cartBadge">0</span>
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <h2>Tu Carrito de <span style="color: var(--accent-color);">Compras</span></h2>
        
        <div class="cart-grid" id="cartGrid">
            <div class="cart-card">
                <div id="itemsContainer"></div>
            </div>

            <div class="cart-card" style="height: fit-content;">
                <h3>Resumen del Pedido</h3>
                <h2 id="cartTotal" style="color: #eab308;">$0.00 MXN</h2>
                
                <hr style="border-color: rgba(255,255,255,0.05); margin: 20px 0;">
                
                <h3>Datos de Entrega</h3>
                <form id="checkoutForm">
                    <div class="form-group">
                        <label>Nombre Completo</label>
                        <input type="text" id="clientName" required placeholder="Ej. Juan Pérez">
                    </div>
                    <div class="form-group">
                        <label>Teléfono de Contacto</label>
                        <input type="tel" id="clientPhone" required placeholder="Ej. 2721234567">
                    </div>
                    <button type="submit" class="btn-checkout">
                        <i class="fab fa-whatsapp"></i> Confirmar Pedido
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let carrito = JSON.parse(localStorage.getItem('carrito')) || [];

        function actualizarBadge() {
            const badge = document.getElementById('cartBadge');
            if (badge) {
                const totalItems = carrito.reduce((sum, item) => sum + item.cantidad, 0);
                badge.innerText = totalItems;
            }
        }

        function renderCarrito() {
            const container = document.getElementById('itemsContainer');
            const totalText = document.getElementById('cartTotal');
            actualizarBadge();
            
            if (carrito.length === 0) {
                document.getElementById('cartGrid').innerHTML = `
                    <div class="cart-card" style="grid-column: 1 / -1; text-align: center; padding: 50px;">
                        <i class="fas fa-shopping-basket" style="font-size: 3rem; color: #475569; margin-bottom: 15px;"></i>
                        <p style="color: #94a3b8;">Tu carrito está vacío. ¡Ve al catálogo y agrega tus equipos!</p>
                        <a href="/catalogo" style="color: var(--accent-color); text-decoration: none; font-weight: bold;">Volver al Catálogo</a>
                    </div>`;
                return;
            }

            container.innerHTML = '';
            let total = 0;

            carrito.forEach((item, index) => {
                total += item.precio * item.cantidad;
                container.innerHTML += `
                    <div class="cart-item">
                        <img src="${item.imagen}" alt="${item.titulo}">
                        <div class="item-details">
                            <h4>${item.titulo}</h4>
                            <p>Modelo: ${item.modelo}</p>
                            <p style="color: #eab308; font-weight: bold; margin-top: 4px;">$${Number(item.precio).toLocaleString('es-MX')} MXN</p>
                        </div>
                        <div class="qty-controls">
                            <button class="qty-btn" onclick="cambiarCantidad(${index}, -1)">-</button>
                            <span>${item.cantidad}</span>
                            <button class="qty-btn" onclick="cambiarCantidad(${index}, 1)">+</button>
                        </div>
                        <button class="delete-btn" onclick="eliminarItem(${index})"><i class="fas fa-trash"></i></button>
                    </div>`;
            });

            totalText.innerText = `$${total.toLocaleString('es-MX')} MXN`;
        }

        function cambiarCantidad(index, cambio) {
            carrito[index].cantidad += cambio;
            if (carrito[index].cantidad <= 0) {
                carrito.splice(index, 1);
            }
            localStorage.setItem('carrito', JSON.stringify(carrito));
            renderCarrito();
        }

        function eliminarItem(index) {
            carrito.splice(index, 1);
            localStorage.setItem('carrito', JSON.stringify(carrito));
            renderCarrito();
        }

        document.getElementById('checkoutForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const nombre = document.getElementById('clientName').value.trim();
            const telefono = document.getElementById('clientPhone').value.trim();
            
            // Generamos la cadena limpia de texto para guardar en la columna 'resumen_productos'
            const productosDetalle = carrito.map(i => `${i.cantidad}x ${i.titulo} (${i.modelo})`).join(', ');
            const total = carrito.reduce((sum, i) => sum + (i.precio * i.cantidad), 0);

            try {
                // Forzamos la ruta absoluta desde la raíz del dominio para evitar el error 404 en Render
                const response = await fetch('/api/pedidos/nuevo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        nombre: nombre, 
                        telefono: telefono, 
                        productos: productosDetalle, 
                        total: total 
                    })
                });

                const resultado = await response.json();

                if (response.ok && resultado.success) {
                    // Generación del mensaje para WhatsApp
                    let mensajeWa = `Hola SVO Orizaba, me interesa concretar la compra del siguiente pedido:\n\n`;
                    mensajeWa += `👤 *Cliente:* ${nombre}\n`;
                    mensajeWa += `📞 *Teléfono:* ${telefono}\n\n`;
                    mensajeWa += `📦 *Productos:* \n`;
                    
                    carrito.forEach(i => {
                        mensajeWa += `- ${i.cantidad}x ${i.titulo} [${i.modelo}] ($${(i.precio * i.cantidad).toLocaleString('es-MX')} MXN)\n`;
                    });
                    
                    mensajeWa += `\n💰 *Total Neto:* $${total.toLocaleString('es-MX')} MXN`;
                    
                    // Limpieza del almacenamiento local
                    localStorage.removeItem('carrito');

                    // Apertura de WhatsApp en pestaña nueva
                    const urlWa = `https://wa.me/522721569109?text=${encodeURIComponent(mensajeWa)}`;
                    window.open(urlWa, '_blank');
                    
                    // Redirección limpia
                    window.location.href = '/catalogo';
                } else {
                    alert("❌ Error del servidor: " + (resultado.message || "No se pudo registrar el pedido."));
                }
            } catch (error) {
                console.error("❌ Error en la petición Fetch:", error);
                alert("❌ Ocurrió un error de red al intentar enviar tu pedido.");
            }
        });

        // Carga inicial
        renderCarrito();
    </script>
</body>
</html>